---
import SectionHeading from '@/components/ui/SectionHeading.astro'

const features = [
  {
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    title: 'Blazing Fast',
    description:
      'Built on Astro with zero JavaScript by default. Your pages load instantly with static HTML.',
  },
  {
    icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01',
    title: 'Tailwind CSS v4',
    description:
      'Utility-first CSS with the latest Tailwind v4. CSS-first configuration with design tokens built in.',
  },
  {
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
    title: 'TypeScript',
    description:
      'Full TypeScript support with strict mode. Catch errors at build time, not in production.',
  },
  {
    icon: 'M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z',
    title: 'Responsive Layout',
    description:
      'Mobile-first design that looks great on every screen size. No compromises on any device.',
  },
  {
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
    title: 'SEO Ready',
    description:
      'Semantic HTML, meta tags, and Open Graph built in. Search engines will love your site.',
  },
  {
    icon: 'M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4',
    title: 'Easy to Customize',
    description:
      'Clean component architecture. Change colors, fonts, and content with minimal effort.',
  },
]
---

<section id="features" class="py-20 sm:py-28">
  <div class="section-container">
    <SectionHeading
      label="Features"
      title="Everything you need, nothing you don't"
      description="A carefully curated set of features that actually matter for shipping a landing page."
    />

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((feature, i) => (
          <div
            class="fade-in group rounded-2xl border bg-muted/20 p-6 transition-all hover:border-accent/30 hover:bg-muted/40"
            style={`transition-delay: ${i * 80}ms`}
          >
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10 text-accent transition-colors group-hover:bg-accent/20">
              <svg
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d={feature.icon}
                />
              </svg>
            </div>
            <h3 class="mt-4 text-lg font-semibold">{feature.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
