---
import SectionHeading from '@/components/ui/SectionHeading.astro'

const techs = [
  { name: 'Astro', color: 'bg-orange-50 text-orange-700 border-orange-200' },
  {
    name: 'Tailwind CSS',
    color: 'bg-sky-50 text-sky-700 border-sky-200',
  },
  {
    name: 'TypeScript',
    color: 'bg-blue-50 text-blue-700 border-blue-200',
  },
  { name: 'Vite', color: 'bg-violet-50 text-violet-700 border-violet-200' },
  { name: 'Vercel', color: 'bg-neutral-50 text-neutral-700 border-neutral-200' },
  { name: 'Netlify', color: 'bg-teal-50 text-teal-700 border-teal-200' },
]
---

<section class="border-t py-14">
  <div class="section-container">
    <p class="mb-6 text-center text-sm text-muted-foreground">
      Built with modern tools you already know
    </p>
    <div class="flex flex-wrap items-center justify-center gap-3">
      {
        techs.map((tech) => (
          <span
            class={`rounded-full border px-4 py-1.5 text-sm font-medium ${tech.color}`}
          >
            {tech.name}
          </span>
        ))
      }
    </div>
  </div>
</section>
