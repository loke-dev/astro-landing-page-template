---
import SectionHeading from '@/components/ui/SectionHeading.astro'

const steps = [
  {
    number: '01',
    title: 'Clone the template',
    description:
      'Use the GitHub template button or clone the repository directly.',
    code: 'git clone https://github.com/you/astro-landing-page-template',
  },
  {
    number: '02',
    title: 'Install & customize',
    description:
      'Install dependencies and make it yours. Change colors, content, and layout.',
    code: 'pnpm install && pnpm dev',
  },
  {
    number: '03',
    title: 'Deploy anywhere',
    description:
      'Push to Vercel, Netlify, or any static host. Zero config deployment.',
    code: 'pnpm build',
  },
]
---

<section id="how-it-works" class="border-y bg-muted/20 py-20 sm:py-28">
  <div class="section-container">
    <SectionHeading
      label="Get started"
      title="Up and running in 60 seconds"
      description="Three simple steps to launch your landing page."
    />

    <div class="mt-16 grid gap-8 lg:grid-cols-2 lg:gap-16">
      <div class="flex flex-col gap-8">
        {
          steps.map((step) => (
            <div class="fade-in flex gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-accent/10 text-sm font-bold text-accent">
                {step.number}
              </div>
              <div>
                <h3 class="font-semibold">{step.title}</h3>
                <p class="mt-1 text-sm text-muted-foreground">
                  {step.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>

      <div class="fade-in overflow-hidden rounded-2xl border bg-foreground">
        <div class="flex items-center gap-2 border-b border-white/10 px-4 py-3">
          <div class="h-3 w-3 rounded-full bg-white/20"></div>
          <div class="h-3 w-3 rounded-full bg-white/20"></div>
          <div class="h-3 w-3 rounded-full bg-white/20"></div>
          <span class="ml-2 text-xs text-white/40">terminal</span>
        </div>
        <div class="p-5 font-mono text-sm leading-relaxed">
          {
            steps.map((step, i) => (
              <>
                {i > 0 && <div class="mt-3" />}
                <div class="text-white/50">
                  <span class="text-accent">$</span>{' '}
                  <span class="text-white/90">{step.code}</span>
                </div>
              </>
            ))
          }
          <div class="mt-4 text-accent">Ready to launch! 🚀</div>
        </div>
      </div>
    </div>
  </div>
</section>
