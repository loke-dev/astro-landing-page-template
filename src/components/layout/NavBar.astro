---
const links = [
  { label: 'Features', href: '#features' },
  { label: 'How it works', href: '#how-it-works' },
  { label: 'Stats', href: '#stats' },
]
---

<header id="navbar" class="fixed top-0 z-50 w-full">
  <div class="section-container flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
      <div
        class="flex h-8 w-8 items-center justify-center rounded-lg bg-accent"
      >
        <svg
          class="h-4 w-4 text-white"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13 10V3L4 14h7v7l9-11h-7z"></path>
        </svg>
      </div>
      <span>Launchpad</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-sm text-muted-foreground transition-colors hover:text-foreground"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="https://github.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-9 items-center rounded-lg bg-foreground px-4 text-sm font-medium text-background transition-opacity hover:opacity-90"
      >
        Get Started
      </a>
    </nav>

    <button
      id="mobile-toggle"
      class="flex h-9 w-9 items-center justify-center rounded-lg border md:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg
        class="h-4 w-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          id="hamburger-icon"
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="hidden border-b bg-background/95 backdrop-blur-sm md:hidden"
  >
    <div class="section-container flex flex-col gap-4 py-4">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="mobile-link text-sm text-muted-foreground transition-colors hover:text-foreground"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="https://github.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-9 items-center justify-center rounded-lg bg-foreground px-4 text-sm font-medium text-background transition-opacity hover:opacity-90"
      >
        Get Started
      </a>
    </div>
  </div>
</header>

<script>
  import '@/scripts/navbar'
</script>
